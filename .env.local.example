# --- Database (Postgres via Prisma) ---
# Recommended: Neon free tier — sign up, create a project, copy the pooled connection string.
#   https://neon.tech
# After setting this:
#   npm run db:push       # create tables
#   npm run db:seed       # insert sample orders
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Auth.js (NextAuth v5) ---
# Required. Used to encrypt JWT session cookies.
# Generate with: npx auth secret
#   or:           node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# --- Google OAuth (optional — enables "Continue with Google" on /admin/login) ---
# 1. Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# 2. Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 3. Add your Gmail address to GOOGLE_ROLE_ALLOWLIST in lib/admin-users.ts
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Stripe (test keys) ---
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
